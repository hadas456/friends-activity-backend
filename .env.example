# PostgreSQL connection string (Neon or any Postgres-compatible URL)
DATABASE_URL=postgres://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# GitHub Personal Access Token — requires public_repo and read:user scopes
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# API key required on all non-health endpoints (X-API-Key header)
API_KEY=your-chosen-secret-key

# Set to "false" to disable SSL (local Postgres only, never in production)
# DATABASE_SSL=false
